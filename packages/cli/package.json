{
  "name": "@ensmetadata/cli",
  "version": "0.4.1",
  "description": "CLI for managing AI agent metadata on ENS using ERC-8004",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ens-metadata": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "SKILL.md",
    "README.md",
    "examples"
  ],
  "scripts": {
    "version:patch": "pnpm version patch --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "cli": "bun src/cli.ts",
    "build": "tsup",
    "publish:cli": "pnpm build && pnpm publish --access public",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint",
    "lint": "biome check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@ensdomains/ensjs": "^4.2.2",
    "@ensmetadata/sdk": "workspace:*",
    "ink": "^6.8.0",
    "pastel": "^3.0.0",
    "react": "^19.2.5",
    "viem": "2.48.1",
    "zod": "^3.25.76"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@ensmetadata/schemas": "workspace:*",
    "@ensmetadata/shared": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/react": "18.3.23",
    "tsconfig": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
