{
  "name": "@ensmetadata/schemas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "publish:schema": "tsx ./scripts/publish-schema.ts",
    "publish:globals": "tsx ./scripts/publish-globals.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./published": "./src/published.ts",
    "./registry": "./published/_registry.json",
    "./latest": "./published/_latest.json"
  },
  "dependencies": {
    "@ensmetadata/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "viem": "2.48.1"
  }
}
