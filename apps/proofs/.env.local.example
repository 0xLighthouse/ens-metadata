# Privy app id (client-side, public)
NEXT_PUBLIC_PRIVY_APP_ID=

# Mainnet RPC URL for ENS reads
NEXT_PUBLIC_RPC_URL=

# Attester worker base URL — defaults to http://localhost:8787 (wrangler dev)
NEXT_PUBLIC_ATTESTER_URL=

# Comma-separated list of attester key addresses to trust on the verify page.
# In dev, set this to the address printed by `pnpm attester` on startup
# (the same address derived from ATTESTER_PRIVATE_KEY in workers/attester/.dev.vars).
NEXT_PUBLIC_TRUSTED_ATTESTERS=
